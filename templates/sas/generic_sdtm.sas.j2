{% include 'domain_header.sas.j2' %}

*** {{ domain }} - {{ domain_label }} ***;
%pre(var={{ domain|lower }});

data {{ domain|lower }}1;
    set {{ domain|lower }};

    length STUDYID USUBJID $200;
    STUDYID=strip(_PROJECT);
    USUBJID=strip(STUDYID)||'-'||strip(SITEID)||'-'||strip(SUBJID);

    /* Variable assignments */
{% for var in variables %}
{% if var.origin == 'Assigned' and var.name not in ['DOMAIN', 'STUDYID', 'USUBJID'] %}
    {{ var.name }} = "&{{ var.name }}.";
{% elif var.origin == 'CRF' and var.codelist %}
    if strip(_{{ var.name }})="Yes" then {{ var.name }}='Y';
    else if strip(_{{ var.name }})="No" then {{ var.name }}='N';
{% elif var.origin == 'CRF' %}
    {{ var.name }}=strip(_{{ var.name }});
{% elif var.generation == 'ai_required' %}
    /* [AI-GEN-START] domain={{ domain }} variable={{ var.name }} */
    /* algorithm: {{ var.algorithm }} */
    /* TODO: AI-generated logic for {{ var.name }} */
    /* [AI-GEN-END] */
{% endif %}
{% endfor %}

    /* Date variables */
{% for var in variables %}
{% if 'DTC' in var.name or 'DAT' in var.name %}
    %date(invar=_{{ var.name }}_RAW,outvar={{ var.name }});
{% endif %}
{% endfor %}

    DOMAIN="{{ domain }}";
    drop _:;
run;

proc sort data={{ domain|lower }}1;
    by studyid usubjid;
run;

/**********---------- Create Final Dataset ----------**********/
data final;
    set {{ domain|lower }}1;
    by studyid usubjid;
    if first.usubjid then {{ domain }}SEQ=0;
    {{ domain }}SEQ+1;
run;

%msdtm_attrib(indsn=final,outdsn=sdtm.{{ domain }},domain={{ domain }});

/**********---------- SUPP{{ domain }} ----------**********/
{% if supp_qualifiers %}
data supp{{ domain|lower }};
    set final;
    length RDOMAIN $2 IDVAR $8 IDVARVAL $40
           QNAM $8 QLABEL $40 QVAL $200 QORIG $40;
    RDOMAIN = "{{ domain }}";
    IDVAR = "{{ domain }}SEQ";
    IDVARVAL = strip(put({{ domain }}SEQ, best.));
{% for sq in supp_qualifiers %}
{% if sq.raw_source and sq.sub_part %}
    /* Substring extraction: {{ sq.source_algorithm }} */
    if length(strip(_{{ sq.raw_source }})) > ({{ sq.sub_part }} - 1) * 200 then do;
        QNAM = "{{ sq.qnam }}";
        QLABEL = "{{ sq.qlabel }}";
        QVAL = strip(substr(_{{ sq.raw_source }}, ({{ sq.sub_part }} - 1) * 200 + 1, 200));
        QORIG = "{{ sq.origin }}";
        output;
    end;
{% elif sq.raw_source %}
    if strip(_{{ sq.raw_source }}) ne "" then do;
        QNAM = "{{ sq.qnam }}";
        QLABEL = "{{ sq.qlabel }}";
        QVAL = strip(_{{ sq.raw_source }});
        QORIG = "{{ sq.origin }}";
        output;
    end;
{% elif sq.direct_value %}
    QNAM = "{{ sq.qnam }}";
    QLABEL = "{{ sq.qlabel }}";
    QVAL = "{{ sq.direct_value }}";
    QORIG = "{{ sq.origin }}";
    output;
{% else %}
    /* [AI-GEN-START] domain=SUPP{{ domain }} variable={{ sq.qnam }} */
    /* source: {{ sq.source_algorithm }} */
    /* TODO: AI-generated SUPP logic for {{ sq.qnam }} */
    /* [AI-GEN-END] */
{% endif %}
{% endfor %}
    keep STUDYID RDOMAIN USUBJID IDVAR IDVARVAL QNAM QLABEL QVAL QORIG;
run;

proc sort data=supp{{ domain|lower }};
    by STUDYID RDOMAIN USUBJID IDVAR IDVARVAL QNAM;
run;

%msdtm_attrib(indsn=supp{{ domain|lower }},outdsn=sdtm.supp{{ domain }},domain=supp{{ domain }});
{% endif %}

*** XPT ***;
%sdtm_xpt(indata={{ domain }},in=sdtm,out=%str(&psdtm\xpt),nocontent=);
{% if supp_qualifiers %}
%sdtm_xpt(indata=supp{{ domain }},in=sdtm,out=%str(&psdtm\xpt),nocontent=);
{% endif %}

*** check log ***;
%mchecklog(in=SDTM, name={{ domain }});
