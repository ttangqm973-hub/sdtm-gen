*** general setup ****************************************************************************;
%macro setpath;
    %global _currentpath_ pgmname;
    %local currentpgmname cur_pgm;
    proc sql noprint;
        select xpath into: currentpgmname from sashelp.vextfl where upcase(xpath) like '%.SAS';
    quit;
    %let _currentpath_=%sysfunc(PRXCHANGE(s/(.*)\\.*/\1/,-1,&currentpgmname));
    %let cur_pgm=%qscan(%bquote(&currentpgmname),-1,/\);
    %let pgmname=%qscan(&cur_pgm,1,.);
    %inc "&_currentpath_.\_setup.sas";
%mend setpath;
%setpath;
*** end of general setup *********************************************************************;

proc datasets lib=work kill memtype=data nolist;
quit;
%let domain={{ domain }};
*** start main program **********************;

/* Date processing macro */
%macro date(invar=,outvar=);
    _y=input(scan(&invar.,1,''),??best.);
    _m=input(scan(&invar.,2,''),??best.);
    _d=input(scan(&invar.,3,''),??best.);
    if _y^=. and _m^=. and _d^=. then &outvar=strip(put(_y,best.))||"-"||strip(put(_m,z2.))||"-"||strip(put(_d,z2.));
    else if _y^=. and _m^=. and _d=. then &outvar=strip(put(_y,best.))||"-"||strip(put(_m,z2.));
    else if _y^=. and _m=. and _d=. then &outvar=strip(put(_y,best.));
    if &outvar="0" then &outvar="";
    drop _y _m _d;
%mend;

/* RAW data preprocessing macro */
%macro pre(var=);
    proc contents data=raw.&var out=_&var noprint;
    run;
    data _null_;
        set _&var end=eof;
        call symputx("varname"||strip(put(_n_,best.)),name);
        if eof then call symputx("tot",_n_);
    run;
    data &var;
        set raw.&var;
        format _all_;
        informat _all_;
        length DOMAIN SUBJID $200;
        DOMAIN=upcase("&domain.");
        SUBJID=strip(SUBJECT);
        %do i=1 %to &tot;
            rename &&varname&i=_&&varname&i;
        %end;
    run;
    proc sort data=&var;
        by subjid;
    run;
%mend;
